{
    "servers": {
        "aspire": {
            "type": "stdio",
            "command": "aspire",
            "args": [
                "agent",
                "mcp",
                "--nologo",
                "--non-interactive",
                "--log-level",
                "Error"
            ]
        },
        "microsoft-learn": {
            "type": "http",
            "url": "https://learn.microsoft.com/api/mcp"
        },
        "fluent-ui-blazor": {
            "type": "stdio",
            "command": "fluentui-mcp"
        }
    }
}
