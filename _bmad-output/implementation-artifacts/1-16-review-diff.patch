+schema_version: '1.0.0'
+gate: governance-completeness
+source_authority:
+  - _bmad-output/planning-artifacts/architecture.md
+  - docs/exit-criteria/
+  - tests/fixtures/
+diagnostic_policy:
+  safe_fields:
+    - gate
+    - criterion_id
+    - artifact_path
+    - owner
+    - status
+    - bounded_category
+    - safe_hash
+  forbidden_fields:
+    - raw_payload
+    - file_content
+    - diff
+    - provider_token
+    - credential_material
+    - tenant_data
+    - local_absolute_path
+criteria:
+  - criterion_id: C0
+    title: Contract Spine source of truth
+    owner: Architecture
+    status: approved
+    artifact_path: src/Hexalith.Folders.Contracts/openapi/hexalith.folders.v1.yaml
+    verification_command: .\tests\tools\run-contract-spine-gates.ps1 -NoRestore
+    result_summary: OpenAPI Contract Spine exists and is consumed by contract, client, and parity gates.
+    open_policy_placeholders: []
+  - criterion_id: C1
+    title: Capacity target evidence
+    owner: Release Readiness
+    status: reference_pending
+    artifact_path: tests/load/README.md
+    verification_command: dotnet build Hexalith.Folders.slnx --no-restore
+    result_summary: Load-test harness placeholder exists; release target calibration is deferred to Epic 7.
+    open_policy_placeholders:
+      - id: C1-capacity-calibration
+        owner: Release Readiness
