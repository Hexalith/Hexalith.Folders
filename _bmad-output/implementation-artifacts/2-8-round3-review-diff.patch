+                .ConfigureAwait(true);
+
+            conflict.StatusCode.ShouldBe(HttpStatusCode.Conflict);
+            host.Repository.EventsAppended.ShouldBe(1);
+        }
+        finally
+        {
+            await host.DisposeAsync().ConfigureAwait(true);
+        }
+    }
+
+    [Fact]
