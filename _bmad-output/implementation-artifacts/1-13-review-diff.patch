diff --git a/tests/Hexalith.Folders.Contracts.Tests/OpenApi/ParityOracleGeneratorTests.cs b/tests/Hexalith.Folders.Contracts.Tests/OpenApi/ParityOracleGeneratorTests.cs
new file mode 100644
