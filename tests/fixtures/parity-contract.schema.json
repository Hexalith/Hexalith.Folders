{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:hexalith-folders:fixtures:parity-contract-row-seed:v2",
  "title": "Hexalith Folders Parity Contract Row Seed",
  "description": "Fixture/oracle input row shape for future C13 parity rows. This is not the public product contract and does not define final OpenAPI semantics.",
  "type": "object",
  "additionalProperties": false,
  "ownership": {
    "owner_workstream": "Phase 1 Contract Spine and C13 parity-oracle stories",
    "future_test_use": "Future parity oracle validation for REST, SDK, CLI, and MCP transport and behavioral equivalence rows.",
    "known_omissions": [
      "No complete generated operation inventory",
      "No final canonical error catalog",
      "No generated oracle implementation",
      "No final OpenAPI path or schema semantics"
    ],
    "mutation_rules": [
      "Extend row shape only when the corresponding parity story owns the behavior.",
      "Do not encode public API endpoint or DTO schema semantics in this fixture schema.",
      "Keep adapter names and failure kinds bounded so unknown values fail before test consumption."
    ],
    "non_policy_placeholder": true,
    "synthetic_data_only": true
  },
  "required": [
    "operation_id",
    "operation_family",
    "read_consistency_class",
    "transport_parity",
    "behavioral_parity",
    "outcome_mapping",
    "adapter_expectations",
    "ownership"
  ],
  "properties": {
    "operation_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Z][A-Za-z0-9]*$"
    },
    "operation_family": {
      "enum": [
        "mutating_command",
        "query_status",
        "context_query",
        "audit",
        "operations_console_projection"
      ]
    },
    "read_consistency_class": {
      "enum": [
        "not_applicable",
        "snapshot-per-task",
        "read-your-writes",
        "eventually-consistent"
      ]
    },
    "transport_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auth_outcome_class",
        "error_code_set",
        "idempotency_key_rule",
        "audit_metadata_keys",
        "correlation_field_path",
        "terminal_states"
      ],
      "properties": {
        "auth_outcome_class": {
          "enum": [
            "tenant_authorized",
            "tenant_access_denied",
            "folder_acl_denied",
            "audit_access_denied",
            "credential_missing",
            "safe_not_found"
          ]
        },
        "error_code_set": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/canonical_error_category"
          }
        },
        "idempotency_key_rule": {
          "enum": [
            "required_for_mutating_command",
            "required_with_operation_id",
            "not_accepted_for_non_mutating_operation"
          ]
        },
        "audit_metadata_keys": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        },
        "correlation_field_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(headers|problem|result|metadata)\\.[A-Za-z0-9_.-]+$"
        },
        "terminal_states": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        }
      }
    },
    "behavioral_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pre_sdk_error_class",
        "idempotency_key_sourcing",
        "correlation_id_sourcing",
        "task_id_sourcing",
        "credential_sourcing",
        "cli_exit_code",
        "mcp_failure_kind"
      ],
      "properties": {
        "pre_sdk_error_class": {
          "enum": [
            "none",
            "usage_error",
            "client_configuration_error",
            "credential_missing",
            "local_validation_error"
          ]
        },
        "idempotency_key_sourcing": {
          "enum": [
            "not_accepted",
            "caller_provided",
            "sdk_provider",
            "cli_flag",
            "cli_allow_auto_key",
            "mcp_tool_input"
          ]
        },
        "correlation_id_sourcing": {
          "enum": [
            "caller_provided",
            "sdk_provider",
            "sdk_generated",
            "cli_flag",
            "cli_generated",
            "mcp_tool_input",
            "mcp_generated"
          ]
        },
        "task_id_sourcing": {
          "enum": [
            "not_task_scoped",
            "caller_provided",
            "cli_flag",
            "mcp_tool_input"
          ]
        },
        "credential_sourcing": {
          "enum": [
            "sdk_configuration",
            "sdk_access_token_provider",
            "hexalith_token_env",
            "hexalith_credentials_file",
            "cli_token_flag",
            "mcp_auth_token",
            "mcp_auth_token_file"
          ]
        },
        "cli_exit_code": {
          "$ref": "#/$defs/cli_exit_code"
        },
        "mcp_failure_kind": {
          "$ref": "#/$defs/mcp_failure_kind"
        }
      }
    },
    "outcome_mapping": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "canonical_error_category",
          "cli_exit_code",
          "mcp_failure_kind",
          "pre_sdk_error_class"
        ],
        "properties": {
          "canonical_error_category": {
            "$ref": "#/$defs/canonical_error_category"
          },
          "cli_exit_code": {
            "$ref": "#/$defs/cli_exit_code"
          },
          "mcp_failure_kind": {
            "$ref": "#/$defs/mcp_failure_kind"
          },
          "pre_sdk_error_class": {
            "enum": [
              "none",
              "usage_error",
              "client_configuration_error",
              "credential_missing",
              "local_validation_error"
            ]
          }
        }
      }
    },
    "adapter_expectations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/adapter_name"
      }
    },
    "ownership": {
      "$ref": "#/$defs/ownership"
    }
  },
  "$defs": {
    "adapter_name": {
      "enum": [
        "rest",
        "sdk",
        "cli",
        "mcp",
        "ui"
      ]
    },
    "canonical_error_category": {
      "enum": [
        "success",
        "authentication_failure",
        "client_configuration_error",
        "credential_missing",
        "credential_reference_missing",
        "credential_reference_invalid",
        "tenant_access_denied",
        "cross_tenant_access_denied",
        "folder_acl_denied",
        "audit_access_denied",
        "validation_error",
        "workspace_locked",
        "lock_conflict",
        "lock_expired",
        "lock_not_owned",
        "stale_workspace",
        "authorization_revocation_detected",
        "workspace_not_ready",
        "workspace_preparation_failed",
        "dirty_workspace",
        "commit_failed",
        "file_operation_failed",
        "path_validation_failed",
        "idempotency_conflict",
        "input_limit_exceeded",
        "response_limit_exceeded",
        "query_timeout",
        "provider_readiness_failed",
        "provider_failure_known",
        "unknown_provider_outcome",
        "provider_permission_insufficient",
        "provider_unavailable",
        "provider_rate_limited",
        "unsupported_provider_capability",
        "repository_binding_unavailable",
        "branch_ref_policy_invalid",
        "repository_conflict",
        "duplicate_binding",
        "reconciliation_required",
        "not_found",
        "state_transition_invalid",
        "read_model_unavailable",
        "projection_stale",
        "projection_unavailable",
        "range_unsatisfiable",
        "failed_operation",
        "redacted",
        "internal_error"
      ]
    },
    "cli_exit_code": {
      "enum": [
        0,
        1,
        64,
        65,
        66,
        67,
        68,
        69,
        70,
        71,
        72,
        73,
        74,
        75
      ]
    },
    "mcp_failure_kind": {
      "enum": [
        "none",
        "authentication_failure",
        "usage_error",
        "credential_missing",
        "credential_reference_invalid",
        "tenant_access_denied",
        "cross_tenant_access_denied",
        "folder_acl_denied",
        "audit_access_denied",
        "workspace_locked",
        "lock_conflict",
        "lock_expired",
        "lock_not_owned",
        "stale_workspace",
        "authorization_revocation_detected",
        "idempotency_conflict",
        "validation_error",
        "input_limit_exceeded",
        "response_limit_exceeded",
        "query_timeout",
        "provider_readiness_failed",
        "provider_failure_known",
        "unknown_provider_outcome",
        "provider_permission_insufficient",
        "provider_unavailable",
        "provider_rate_limited",
        "repository_binding_unavailable",
        "branch_ref_policy_invalid",
        "workspace_not_ready",
        "workspace_preparation_failed",
        "dirty_workspace",
        "commit_failed",
        "file_operation_failed",
        "path_validation_failed",
        "repository_conflict",
        "duplicate_binding",
        "unsupported_provider_capability",
        "reconciliation_required",
        "not_found",
        "state_transition_invalid",
        "read_model_unavailable",
        "projection_stale",
        "projection_unavailable",
        "range_unsatisfiable",
        "failed_operation",
        "redacted",
        "internal_error"
      ]
    },
    "ownership": {
      "type": "object",
      "required": [
        "owner_workstream",
        "future_test_use",
        "known_omissions",
        "mutation_rules",
        "non_policy_placeholder",
        "synthetic_data_only"
      ],
      "additionalProperties": false,
      "properties": {
        "owner_workstream": {
          "type": "string",
          "minLength": 1
        },
        "future_test_use": {
          "type": "string",
          "minLength": 1
        },
        "known_omissions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "mutation_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "non_policy_placeholder": {
          "const": true
        },
        "synthetic_data_only": {
          "const": true
        }
      }
    }
  }
}
