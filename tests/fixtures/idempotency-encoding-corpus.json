      "code_points": "U+0043 U+0061 U+0066 U+0065 U+00E9",
      "equivalence_classification": "equivalent-after-generated-normalization-for-declared-normalization-insensitive-field",
      "expected_intent": "Normalization-sensitive metadata-only placeholder; final helper owns canonicalization.",
      "synthetic_data_only": true,
      "contains_payload_material": false
    },
    {
