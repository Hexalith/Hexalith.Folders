{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "0.2.0-story-1-5",
  "intent": "Synthetic Unicode, casing, ordering, parser-policy, and malformed-key corpus for future idempotency canonicalization tests.",
  "ownership": {
    "owner_workstream": "Idempotency, encoding, Story 1.12 helper generation, and C13 parity stories",
    "future_test_use": "Future ComputeIdempotencyHash and adapter parity tests consume these cases after final equivalence rules are defined.",
    "known_omissions": [
      "No final canonical hash algorithm",
      "No transport-specific header encoding matrix",
      "No generated helper implementation",
      "No final parity oracle rows"
    ],
    "mutation_rules": [
      "Keep samples metadata-only and synthetic.",
      "Pair invisible or normalization-sensitive values with code-point labels.",
      "Document whether each case is equivalent, non-equivalent, or parser-rejected without implementing canonicalization here."
    ],
    "non_policy_placeholder": true,
    "synthetic_data_only": true
  },
  "cases": [
