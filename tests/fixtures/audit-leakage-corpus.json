    "mutation_rules": [
      "Only synthetic metadata-only samples may be added.",
      "Every new category requires reviewer-visible corpus changes.",
      "Negative controls belong only under tests/fixtures/quarantine/."
    ],
    "non_policy_placeholder": false,
    "synthetic_data_only": true
  },
