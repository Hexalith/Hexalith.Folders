  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Hexalith.Folders/Hexalith.Folders.csproj" />
    <ProjectReference Include="../../src/Hexalith.Folders.Testing/Hexalith.Folders.Testing.csproj" />
  </ItemGroup>
</Project>
